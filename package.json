{
  "name": "neutrx",
  "version": "1.0.0",
  "description": "Security-first TypeScript HTTP client with retry, circuit breaker, bulkhead, cache, metrics, and plugins.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xenial-Devil/neutrx.git"
  },
  "bugs": {
    "url": "https://github.com/Xenial-Devil/neutrx/issues"
  },
  "homepage": "https://github.com/Xenial-Devil/neutrx#readme",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/browser.js",
  "browser": "./dist/esm/browser.js",
  "types": "./dist/types/browser.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/browser.d.ts",
      "browser": {
        "types": "./dist/types/browser.d.ts",
        "default": "./dist/esm/browser.js"
      },
      "node": {
        "types": "./dist/types/index.d.ts",
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "import": "./dist/esm/browser.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/browser.js"
    },
    "./node": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./browser": {
      "types": "./dist/types/browser.d.ts",
      "import": "./dist/esm/browser.js",
      "default": "./dist/esm/browser.js"
    },
    "./plugins": {
      "types": "./dist/types/plugins/PluginManager.d.ts",
      "import": "./dist/esm/plugins/PluginManager.js",
      "require": "./dist/cjs/plugins/PluginManager.js"
    },
    "./errors": {
      "types": "./dist/types/core/NeutrxError.d.ts",
      "import": "./dist/esm/core/NeutrxError.js",
      "require": "./dist/cjs/core/NeutrxError.js"
    },
    "./adapters": {
      "types": "./dist/types/adapters/index.d.ts",
      "browser": "./dist/esm/adapters/browser.js",
      "import": "./dist/esm/adapters/index.js",
      "require": "./dist/cjs/adapters/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('dist-tests', { recursive: true, force: true })\"",
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && npm run build:cjs:pkg",
    "build:cjs:pkg": "node -e \"const fs=require('node:fs'); fs.mkdirSync('dist/cjs', { recursive: true }); fs.writeFileSync('dist/cjs/package.json', JSON.stringify({ type: 'commonjs' }))\"",
    "build:types": "tsc -p tsconfig.types.json && node scripts/generate-browser-types.cjs",
    "start": "node -e \"import('./dist/esm/index.js').then(({ default: Neutrx }) => console.log(Neutrx.name))\"",
    "set-version": "node scripts/set-version.cjs",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:run": "node --test dist-tests/tests/*.test.js",
    "test": "npm run build && npm run test:compile && npm run test:run",
    "coverage": "npm run build && npm run test:compile && node --test --experimental-test-coverage dist-tests/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts examples/**/*.ts tests/**/*.ts",
    "audit": "npm audit --audit-level=high",
    "package:validate": "npm run build && node scripts/validate-package.cjs",
    "release:validate": "npm run validate",
    "validate": "npm run typecheck && npm run lint && npm test && npm run package:validate",
    "ci": "npm run lint && npm run typecheck && npm test && npm run coverage && npm run package:validate"
  },
  "keywords": [
    "neutrx",
    "http",
    "https",
    "typescript",
    "security",
    "ssrf",
    "circuit-breaker",
    "retry",
    "cache",
    "fetch-alternative"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
